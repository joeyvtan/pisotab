PORT=4000
JWT_SECRET=your_super_secret_key_change_this
MQTT_BROKER_URL=mqtt://localhost:1883
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DB_PATH=./pisotab.db
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Firebase (production / Render) ────────────────────────────────────────────
# Paste the entire contents of firebase-service-account.json as a single line.
# Takes priority over FIREBASE_SERVICE_ACCOUNT_PATH when both are set.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── PostgreSQL (production) ────────────────────────────────────────────────────
# Leave DATABASE_URL blank to use the local SQLite file (development).
# Set it to a Postgres connection string in production (e.g. Supabase / Railway).
# DB_SSL=false  ← uncomment only if your provider uses a self-signed cert you trust
DATABASE_URL=
DB_SSL=true

# ── Email (SMTP) — optional. Leave blank to disable email notifications ────────
# Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Use an App Password (not your Gmail login) — see myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=JJT PisoTab <noreply@jjtpisotab.com>
APP_URL=http://localhost:3000
