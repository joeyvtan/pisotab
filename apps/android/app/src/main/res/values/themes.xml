<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — DayNight switches between values/ and values-night/ automatically -->
    <style name="Theme.PisoTab" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorPrimary">#F97316</item>
        <item name="colorPrimaryDark">#EA580C</item>
        <item name="colorAccent">#F97316</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/screen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.PisoTab.Fullscreen" parent="Theme.PisoTab">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">#000000</item>
    </style>

    <!-- Blue theme variant -->
    <style name="Theme.PisoTab.Blue" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorPrimary">#3B82F6</item>
        <item name="colorPrimaryDark">#2563EB</item>
        <item name="colorAccent">#3B82F6</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/screen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Green theme variant -->
    <style name="Theme.PisoTab.Green" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorPrimary">#22C55E</item>
        <item name="colorPrimaryDark">#16A34A</item>
        <item name="colorAccent">#22C55E</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/screen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Toolbar overlay — forces hamburger icon and title to always be white (dark toolbar) -->
    <style name="ToolbarDarkOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorControlNormal">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
    </style>

    <!-- Navigation drawer item text style -->
    <style name="NavItemText">
        <item name="android:textSize">14sp</item>
    </style>
</resources>
