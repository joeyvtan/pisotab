<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:text="PisoTab Setup"
            android:textSize="24sp"
            android:textColor="#F1F5F9"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Server URL -->
        <TextView android:text="Backend Server URL" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_server_url"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textUri" android:hint="http://192.168.1.x:4000"
            android:background="#1E293B" android:textColor="#F1F5F9" android:textColorHint="#475569"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <!-- Device ID -->
        <TextView android:text="Device ID" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_device_id"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="text" android:hint="dev_abc123"
            android:background="#1E293B" android:textColor="#F1F5F9" android:textColorHint="#475569"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <!-- Device Name -->
        <TextView android:text="Device Name" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_device_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="text" android:hint="Phone 01"
            android:background="#1E293B" android:textColor="#F1F5F9" android:textColorHint="#475569"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <!-- Admin PIN -->
        <TextView android:text="Admin PIN" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_admin_pin"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="numberPassword" android:hint="1234"
            android:background="#1E293B" android:textColor="#F1F5F9" android:textColorHint="#475569"
            android:padding="12dp" android:layout_marginBottom="16dp"/>

        <!-- Kiosk Mode -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="24dp">
            <TextView android:text="Enable Kiosk Mode" android:textColor="#F1F5F9" android:textSize="15sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/sw_kiosk" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Anti-theft Settings -->
        <TextView android:text="Anti-Theft Alarm" android:textColor="#F97316" android:textSize="15sp"
            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:text="Alarm on WiFi disconnect" android:textColor="#F1F5F9" android:textSize="14sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/sw_alarm_wifi" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:text="Alarm on charger disconnect" android:textColor="#F1F5F9" android:textSize="14sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/sw_alarm_charger" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:text="Only alarm during active session" android:textColor="#F1F5F9" android:textSize="14sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/sw_alarm_session_only" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:text="Alarm delay (seconds)" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/et_alarm_delay"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:hint="30"
            android:background="#1E293B" android:textColor="#F1F5F9" android:textColorHint="#475569"
            android:padding="12dp" android:layout_marginBottom="12dp"/>

        <TextView android:text="Alarm sound" android:textColor="#94A3B8" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
        <Button android:id="@+id/btn_alarm_sound"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Default Alarm"
            android:backgroundTint="#1E293B" android:textColor="#F1F5F9"
            android:layout_marginBottom="24dp"/>

        <!-- Floating Timer -->
        <TextView android:text="Floating Timer" android:textColor="#F97316" android:textSize="15sp"
            android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>

        <TextView android:text="Shows remaining time over other apps while the customer is using the device."
            android:textColor="#64748B" android:textSize="12sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:text="Enable floating timer" android:textColor="#F1F5F9" android:textSize="14sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/sw_floating_timer" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_overlay_permission_hint"
            android:text="✓ Permission granted — floating timer is ready."
            android:textColor="#22C55E" android:textSize="11sp" android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Buttons -->
        <Button android:id="@+id/btn_save"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Save Settings"
            android:backgroundTint="#F97316" android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btn_back"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Back"
            android:backgroundTint="#1E293B" android:textColor="#94A3B8"/>

    </LinearLayout>
</ScrollView>
