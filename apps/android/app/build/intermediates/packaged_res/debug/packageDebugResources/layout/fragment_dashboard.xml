<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: Sessions Today + Time Sold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sessions Today" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_sessions_today"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Time Sold Today" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_time_sold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Row 2: Earnings Today + Timer Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Earnings Today" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_earnings_today"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="₱—" android:textColor="#F97316" android:textSize="28sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Timer Status" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_timer_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Idle" android:textColor="#22C55E" android:textSize="18sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Row 3: Battery + Total Coins -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Battery" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_battery"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—%" android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/card_bg"
                android:padding="16dp"
                android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total Coins (Today)" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_total_coins"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="₱—" android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- License status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="License" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_license"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Active" android:textColor="#22C55E" android:textSize="16sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Refresh button -->
        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Refresh"
            android:backgroundTint="#F97316"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
