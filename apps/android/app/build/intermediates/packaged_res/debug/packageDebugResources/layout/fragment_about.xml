<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- App info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="APP" android:textColor="#F97316" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="App Version"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_app_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1.0.0" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="License"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_license_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Checking..." android:textColor="@color/text_secondary" android:textSize="13sp"/>
            </LinearLayout>

            <Button android:id="@+id/btn_activate_license"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Activate License Key"
                android:backgroundTint="#1E3A5F"
                android:textColor="#93C5FD" android:textSize="13sp"/>
        </LinearLayout>

        <!-- Device info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DEVICE" android:textColor="#F97316" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Model"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_device_model"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Android Version"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_android_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Device Owner"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_device_owner"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textColor="@color/text_primary" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Software Update card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SOFTWARE UPDATE" android:textColor="#F97316" android:textSize="11sp"
                android:textStyle="bold" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tv_update_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="You are on the latest version." android:textColor="@color/text_secondary"
                android:textSize="13sp" android:layout_marginBottom="12dp"/>

            <Button android:id="@+id/btn_check_update"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Check for Updates" android:backgroundTint="#F97316"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
